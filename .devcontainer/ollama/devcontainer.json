{
  "name": "Ollama Dev Container",
  "image": "ollama/ollama:latest",
  "workspaceFolder": "/workspaces/${localWorkspaceFolderBasename}",

  "forwardPorts": [11434],

  "containerEnv": {
    // We keep 0.0.0.0 so the service is reachable,
    // but we pass the model name from your .env
    "OLLAMA_HOST": "0.0.0.0",
    "OLLAMA_MODEL": "${localEnv:OLLAMA_MODEL}",
    "OLLAMA_PORT": "${localEnv:OLLAMA_PORT}"
  },

  "postCreateCommand": "apt-get update && apt-get install -y curl && chmod +x ${containerWorkspaceFolder}/.devcontainer/ollama/startup.sh",

  "postStartCommand": "${containerWorkspaceFolder}/.devcontainer/ollama/startup.sh",

  "customizations": {
    "vscode": {
      "extensions": ["ms-vscode-remote.remote-containers"]
    }
  }
}
